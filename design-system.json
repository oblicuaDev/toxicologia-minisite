{
  "name": "Micrositio Toxicología",
  "version": "1.0.0",
  "brand": {
    "name": "Instituto Nacional de Salud (INS)",
    "logo": "https://www.ins.gov.co/Portalweb2025/general-assets/ins-logo.png",
    "logoFallbackText": "INS"
  },
  "typography": {
    "fontFamily": {
      "primary": "'Poppins', sans-serif",
      "source": "https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    },
    "weights": { "light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "headings": {
      "h1": { "fontSize": "2.25rem", "lineHeight": "1.2", "fontWeight": 600, "letterSpacing": "-0.02em", "color": "var(--foreground)" },
      "h2": { "fontSize": "1.875rem", "lineHeight": "1.25", "fontWeight": 600, "letterSpacing": "-0.02em", "color": "var(--foreground)" },
      "h3": { "fontSize": "1.5rem", "lineHeight": "1.3", "fontWeight": 600, "letterSpacing": "-0.01em", "color": "var(--foreground)" },
      "h4": { "fontSize": "1.25rem", "lineHeight": "1.4", "fontWeight": 600 },
      "h5": { "fontSize": "1.125rem", "lineHeight": "1.4", "fontWeight": 600 },
      "h6": { "fontSize": "1rem", "lineHeight": "1.5", "fontWeight": 600 },
      "publicationTitle": { "fontSize": "1.875rem", "fontWeight": 700, "color": "hsl(217 93% 45%)", "note": "Color azul de contraste para títulos de publicación interna" }
    },
    "paragraph": {
      "base": { "fontSize": "1rem", "lineHeight": "1.6", "fontWeight": 400, "color": "var(--foreground)" },
      "small": { "fontSize": "0.875rem", "lineHeight": "1.5", "color": "var(--muted-foreground)" },
      "xs": { "fontSize": "0.75rem", "lineHeight": "1.5", "color": "var(--muted-foreground)" },
      "lead": { "fontSize": "1.125rem", "lineHeight": "1.7", "color": "var(--muted-foreground)" }
    }
  },
  "colors": {
    "mode": "HSL",
    "brand": {
      "primary": { "hex": "#0950de", "hsl": "217 93% 45%", "description": "Azul de énfasis principal INS" }
    },
    "colombiaFlag": {
      "yellow": "#FCD116",
      "blue": "#003893",
      "red": "#CE1126"
    },
    "light": {
      "background": "hsl(0 0% 100%)",
      "foreground": "hsl(220 15% 15%)",
      "card": "hsl(220 14% 98%)",
      "cardForeground": "hsl(220 15% 15%)",
      "primary": "hsl(217 93% 45%)",
      "primaryForeground": "hsl(0 0% 100%)",
      "secondary": "hsl(220 14% 96%)",
      "secondaryForeground": "hsl(220 15% 25%)",
      "muted": "hsl(220 14% 96%)",
      "mutedForeground": "hsl(220 9% 46%)",
      "accent": "hsl(217 90% 96%)",
      "accentForeground": "hsl(217 93% 40%)",
      "destructive": "hsl(0 84% 60%)",
      "success": "hsl(142 71% 45%)",
      "warning": "hsl(38 92% 50%)",
      "info": "hsl(217 93% 45%)",
      "border": "hsl(220 13% 88%)",
      "input": "hsl(220 13% 91%)",
      "ring": "hsl(217 93% 45%)",
      "heroBg": "hsl(217 90% 97%)",
      "heroBorder": "hsl(217 60% 88%)"
    },
    "dark": {
      "background": "hsl(222 20% 8%)",
      "foreground": "hsl(220 14% 95%)",
      "card": "hsl(222 20% 10%)",
      "primary": "hsl(217 93% 55%)",
      "primaryForeground": "hsl(0 0% 100%)",
      "secondary": "hsl(222 20% 18%)",
      "muted": "hsl(222 20% 18%)",
      "mutedForeground": "hsl(220 9% 65%)",
      "accent": "hsl(217 50% 20%)",
      "accentForeground": "hsl(217 93% 70%)",
      "border": "hsl(222 20% 20%)",
      "input": "hsl(222 20% 18%)",
      "ring": "hsl(217 93% 55%)"
    }
  },
  "radius": {
    "base": "0.625rem",
    "sm": "calc(0.625rem - 4px)",
    "md": "calc(0.625rem - 2px)",
    "lg": "0.625rem",
    "pill": "9999px"
  },
  "shadows": {
    "card": "0 1px 3px 0 rgb(0 0 0 / 0.05), 0 1px 2px -1px rgb(0 0 0 / 0.05)",
    "cardHover": "0 4px 6px -1px rgb(0 0 0 / 0.07), 0 2px 4px -2px rgb(0 0 0 / 0.07)",
    "elevated": "0 10px 15px -3px rgb(0 0 0 / 0.08), 0 4px 6px -4px rgb(0 0 0 / 0.08)"
  },
  "spacing": {
    "containerPadding": "2rem",
    "containerMaxWidth": "1400px",
    "section": { "y": "2.5rem" },
    "card": { "padding": "1.5rem", "gap": "0.375rem" }
  },
  "components": {
    "header": {
      "height": "4rem",
      "background": "hsl(var(--background) / 0.95)",
      "backdropBlur": true,
      "borderBottom": "1px solid hsl(var(--border))",
      "sticky": true,
      "zIndex": 50,
      "logoHeight": "2.5rem",
      "navGap": "0.5rem"
    },
    "navLink": {
      "shape": "pill",
      "padding": "0.5rem 1rem",
      "fontSize": "0.875rem",
      "fontWeight": 500,
      "borderRadius": "9999px",
      "borderWidth": "1px",
      "transition": "all 200ms",
      "states": {
        "rest": { "background": "transparent", "color": "hsl(var(--foreground))", "borderColor": "hsl(var(--border))" },
        "hover": { "background": "hsl(var(--primary))", "color": "hsl(var(--primary-foreground))", "borderColor": "hsl(var(--primary))" },
        "active": { "background": "hsl(var(--primary))", "color": "hsl(var(--primary-foreground))", "borderColor": "hsl(var(--primary))" }
      }
    },
    "buttons": {
      "primary": {
        "description": "Acción principal - fondo azul sólido",
        "background": "hsl(var(--primary))",
        "color": "hsl(var(--primary-foreground))",
        "borderRadius": "9999px",
        "borderWidth": "1px",
        "borderColor": "hsl(var(--primary))",
        "padding": "0.5rem 1rem",
        "fontWeight": 500,
        "fontSize": "0.875rem",
        "hover": { "background": "hsl(var(--primary) / 0.9)" }
      },
      "secondary": {
        "description": "Acción secundaria - transparente con borde, hover azul",
        "background": "transparent",
        "color": "hsl(var(--foreground))",
        "borderRadius": "9999px",
        "borderWidth": "1px",
        "borderColor": "hsl(var(--border))",
        "padding": "0.5rem 1rem",
        "fontWeight": 500,
        "fontSize": "0.875rem",
        "hover": {
          "background": "hsl(var(--primary))",
          "color": "hsl(var(--primary-foreground))",
          "borderColor": "hsl(var(--primary))"
        }
      },
      "ghost": {
        "background": "transparent",
        "color": "hsl(var(--foreground))",
        "hover": { "background": "hsl(var(--accent))", "color": "hsl(var(--accent-foreground))" }
      },
      "destructive": {
        "background": "hsl(var(--destructive))",
        "color": "hsl(var(--destructive-foreground))",
        "borderRadius": "9999px"
      },
      "sizes": {
        "sm": { "height": "2.25rem", "padding": "0 0.75rem" },
        "default": { "height": "2.5rem", "padding": "0.5rem 1rem" },
        "lg": { "height": "2.75rem", "padding": "0 2rem" },
        "icon": { "height": "2.5rem", "width": "2.5rem" }
      }
    },
    "card": {
      "background": "hsl(var(--card))",
      "color": "hsl(var(--card-foreground))",
      "borderRadius": "var(--radius)",
      "border": "1px solid hsl(var(--border))",
      "shadow": "card",
      "padding": "1.5rem",
      "hover": { "shadow": "cardHover", "borderColor": "hsl(var(--primary) / 0.3)" }
    },
    "colombiaFlagDivider": {
      "description": "Separador horizontal con colores de la bandera de Colombia",
      "height": "4px",
      "layout": "flex horizontal",
      "segments": [
        { "color": "#FCD116", "name": "yellow", "flex": 2, "widthPercent": 50 },
        { "color": "#003893", "name": "blue",   "flex": 1, "widthPercent": 25 },
        { "color": "#CE1126", "name": "red",    "flex": 1, "widthPercent": 25 }
      ],
      "usage": "Separar secciones principales: header/main, entre bloques de contenido, antes del footer",
      "html": "<div class=\"w-full h-1 flex\"><div class=\"flex-[2] bg-[#FCD116]\"></div><div class=\"flex-1 bg-[#003893]\"></div><div class=\"flex-1 bg-[#CE1126]\"></div></div>"
    },
    "separator": {
      "default": { "height": "1px", "background": "hsl(var(--border))" }
    },
    "badge": {
      "borderRadius": "9999px",
      "padding": "0.125rem 0.625rem",
      "fontSize": "0.75rem",
      "fontWeight": 600,
      "variants": {
        "published": { "background": "hsl(var(--success) / 0.1)", "color": "hsl(var(--success))" },
        "review":    { "background": "hsl(var(--warning) / 0.1)", "color": "hsl(var(--warning))" },
        "draft":     { "background": "hsl(var(--muted))", "color": "hsl(var(--muted-foreground))" }
      }
    },
    "input": {
      "height": "2.5rem",
      "borderRadius": "var(--radius)",
      "border": "1px solid hsl(var(--input))",
      "padding": "0.5rem 0.75rem",
      "fontSize": "0.875rem",
      "background": "hsl(var(--background))",
      "focus": { "ring": "2px solid hsl(var(--ring))" }
    }
  },
  "animations": {
    "fadeIn": "fade-in 0.5s ease-out forwards",
    "transitionBase": "all 200ms ease"
  },
  "breakpoints": {
    "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1400px"
  }
}